# Persistent data directory survives deploys and restarts.
# Account statement CSV, ticker filter, and Telegram toggle are stored here.
option_settings:
  aws:elasticbeanstalk:application:environment:
    DATA_DIR: /var/app/data

container_commands:
  01_create_data_dir:
    command: "mkdir -p /var/app/data && chmod 777 /var/app/data"
